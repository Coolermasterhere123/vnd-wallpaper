<?xml version="1.0" encoding="utf-8"?>
<!--
  VND Wallpaper - Tasker Profile
  
  SETUP INSTRUCTIONS:
  1. Open Tasker → Long-press Profiles tab → Import Profile
  2. Select this XML file
  3. Edit the wallpaper URL in the HTTP Request action to match your Vercel domain
  4. Enable the profile
  
  REQUIREMENTS:
  - Tasker (paid app): https://tasker.joaoapps.com/
  - AutoInput plugin OR use Tasker's built-in Wallpaper Set action
  
  WHAT IT DOES:
  - Triggers daily at 06:00 AM
  - Downloads fresh wallpaper PNG with live exchange rates
  - Sets it as lock screen wallpaper automatically
-->
<TaskerData sr="" dvi="1" tv="6.2.3">
  <Profile sr="prof1" ve="2">
    <cdate>1700000000000</cdate>
    <edate>1700000000000</edate>
    <id>1</id>
    <mid0>1</mid0>
    <nme>VND Wallpaper Daily</nme>
    <Time sr="con0">
      <fh>6</fh>
      <fm>0</fm>
      <rep>1</rep>
      <repval>1440</repval>
      <th>6</th>
      <tm>0</tm>
    </Time>
  </Profile>

  <Task sr="task1">
    <cdate>1700000000000</cdate>
    <edate>1700000000000</edate>
    <id>1</id>
    <nme>Download VND Wallpaper</nme>
    <pri>100</pri>

    <!-- Action 1: HTTP GET wallpaper image -->
    <Action sr="act0" ve="7">
      <code>339</code>
      <!-- HTTP Request -->
      <Str sr="arg0" ve="3">GET</Str>
      <!-- EDIT THIS URL to your Vercel deployment -->
      <Str sr="arg1" ve="3">https://YOUR-APP.vercel.app/api/wallpaper</Str>
      <Int sr="arg2" val="0"/>
      <Int sr="arg3" val="30"/>
      <Str sr="arg4" ve="3"/>
      <Str sr="arg5" ve="3"/>
      <Str sr="arg6" ve="3">%http_response</Str>
      <!-- Output file path -->
      <Str sr="arg7" ve="3">/sdcard/Pictures/vnd-wallpaper.png</Str>
      <Int sr="arg8" val="0"/>
      <Int sr="arg9" val="1"/>
    </Action>

    <!-- Action 2: Wait for download to complete -->
    <Action sr="act1" ve="7">
      <code>30</code>
      <!-- Wait -->
      <Int sr="arg0" val="0"/>
      <Int sr="arg1" val="0"/>
      <Int sr="arg2" val="3"/>
      <Int sr="arg3" val="0"/>
    </Action>

    <!-- Action 3: Set as Lock Screen Wallpaper -->
    <Action sr="act2" ve="7">
      <code>67</code>
      <!-- Set Wallpaper -->
      <Str sr="arg0" ve="3">/sdcard/Pictures/vnd-wallpaper.png</Str>
      <Int sr="arg1" val="1"/>
      <!-- 0=home, 1=lock, 2=both -->
      <Int sr="arg2" val="1"/>
    </Action>

    <!-- Action 4: Flash notification -->
    <Action sr="act3" ve="7">
      <code>83</code>
      <!-- Flash -->
      <Str sr="arg0" ve="3">🇻🇳 VND wallpaper updated!</Str>
      <Int sr="arg1" val="0"/>
    </Action>

  </Task>
</TaskerData>
